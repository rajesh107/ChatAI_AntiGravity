[Unit]
Description=Dynamic Multi-Tenant Marketing Agent (FastAPI)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/chatbot
EnvironmentFile=/home/ubuntu/chatbot/.env
ExecStart=/home/ubuntu/chatbot/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
